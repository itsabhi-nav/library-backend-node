{
  "name": "library-backend-node",
  "version": "1.0.0",
  "description": "Express + TypeScript backend for the library management system (port of the Spring Boot library-backend)",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "ts-node-dev --transpile-only --ignore-watch node_modules src/server.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "migrate": "ts-node scripts/run-migration.ts"
  },
  "keywords": [
    "library",
    "management",
    "api",
    "express",
    "postgresql"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@types/pdfkit": "^0.17.6",
    "axios": "^1.12.2",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.1",
    "form-data": "^4.0.6",
    "helmet": "^8.1.0",
    "node-cron": "^3.0.3",
    "pdfkit": "^0.19.1",
    "pg": "^8.11.3",
    "pino": "^10.0.0",
    "pino-http": "^11.0.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.7.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.15.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  },
  "type": "commonjs"
}
